generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  username  String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  books Book[]
}

enum Role {
  USER
  ADMIN
}

model Book {
  id            Int      @id @default(autoincrement())
  title         String
  author        String
  isbn          String   @unique
  publishedYear Int
  description   String
  available     Boolean  @default(true)
  createdAt     DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id])
}
