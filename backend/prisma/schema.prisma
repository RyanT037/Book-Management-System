generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// Represents a system user who can manage books
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  // Unique handle for the user
  username  String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  books Book[]
}

// Access control levels
enum Role {
  USER 
  ADMIN 
}

// Represents a book entry in the library
model Book {
  id            Int      @id @default(autoincrement())
  title         String
  author        String
  isbn          String   @unique
  publishedYear Int
  description   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relation to the User who added the book
  userId Int
  user   User @relation(fields: [userId], references: [id])
}
